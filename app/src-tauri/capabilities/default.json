{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for Voice Input",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "global-shortcut:default",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister",
    "dialog:default",
    "dialog:allow-open"
  ]
}
